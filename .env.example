# AstraCore Cleanslate — deployment baseline envs
# Copy to .env and replace values for production.

# App runtime
PORT=8080
ENVIRONMENT=production

# Ops security (P0-9)
# Required in real deployment; do NOT keep default in prod.
ASTRACORE_OPS_TOKEN=change-me-strong-random-token
# Optional previous token for zero-downtime rotation window (P9-1).
# During rotation: set old value here, deploy, update callers, then clear.
ASTRACORE_OPS_TOKEN_PREV=

# Sensitive endpoint rate limit (per-IP, rolling window)
ASTRACORE_RATE_LIMIT_PER_MIN=60
ASTRACORE_RATE_LIMIT_WINDOW_SEC=60

# Ops alert thresholds (P1-5)
ASTRACORE_ALERT_ERROR_RATE_WARN_PCT=5
ASTRACORE_ALERT_ERROR_RATE_CRIT_PCT=15
ASTRACORE_ALERT_QUEUE_DEPTH_WARN=5
ASTRACORE_ALERT_QUEUE_DEPTH_CRIT=10

# Optional workspace overrides (defaults are internal runtime paths)
WORKSPACE_CAPTURES_DIR=./workspace/captures
WORKSPACE_MEMORY_DIR=./workspace/memory

# Account auth baseline (P10-2)
ASTRACORE_AUTH_SECRET=change-me-auth-signing-secret
ASTRACORE_AUTH_ACCESS_TTL_SEC=3600
ASTRACORE_AUTH_RESET_TTL_SEC=900
ASTRACORE_AUTH_USERS_FILE=./workspace/memory/auth/users.json
ASTRACORE_AUTH_RESET_FILE=./workspace/memory/auth/reset_tokens.json
